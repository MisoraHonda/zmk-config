#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
                &kp Y &kp U &kp I &kp O &kp P &kp BSPC &kp TILDE
                &kp PIPE &kp H &kp J &kp K &kp L &kp SEMI &kp SQT &kp RET
                &kp B &kp N &kp M &kp COMMA &kp DOT &kp FSLH &kp RSHFT
                &kp TAB &kp LCTRL &kp LALT &kp SPACE &kp ENTER &kp BSPC &kp ESC
            >;
        };
    };
};
