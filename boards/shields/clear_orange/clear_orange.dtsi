#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    default_transform: keymap_transform {
        compatible = "zmk,matrix-transform";
        columns = <7>;
        rows = <4>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(2,6)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5) RC(3,6)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        // 回路図に基づき、列から行方向へスキャンするように修正
        diode-direction = "col2row"; 

        // Row側をプルアップして待ち受けます
        row-gpios
            = <&gpio0 22 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // Row0: 7ピン
            , <&gpio0 24 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // Row1: 8ピン
            , <&gpio1 0  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // Row2: 9ピン
            , <&gpio0 11 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)> // Row3: 10ピン
            ;

        // Col側をスキャン信号として使用します
        col-gpios
            = <&gpio0 31 GPIO_ACTIVE_LOW> // Col0: 20ピン
            , <&gpio0 29 GPIO_ACTIVE_LOW> // Col1: 19ピン
            , <&gpio0 2  GPIO_ACTIVE_LOW> // Col2: 18ピン
            , <&gpio1 15 GPIO_ACTIVE_LOW> // Col3: 17ピン
            , <&gpio1 13 GPIO_ACTIVE_LOW> // Col4: 16ピン
            , <&gpio1 11 GPIO_ACTIVE_LOW> // Col5: 15ピン
            , <&gpio0 10 GPIO_ACTIVE_LOW> // Col6: 14ピン
            ;
    };
};
